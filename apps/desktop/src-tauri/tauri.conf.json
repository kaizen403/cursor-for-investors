{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Neuralyn",
  "version": "0.1.0",
  "identifier": "com.neuralyn.investor-ide",
  "build": {
    "beforeBuildCommand": "pnpm vite:build",
    "beforeDevCommand": "pnpm vite:dev",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "windows": [
      {
        "title": "Neuralyn",
        "label": "main",
        "width": 1400,
        "height": 900,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
